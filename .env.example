DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_ORCHESTRATOR_BOT_TOKEN=
DISCORD_CLAUDE_BOT_TOKEN=
DISCORD_CODEX_BOT_TOKEN=
DISCORD_GEMINI_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_DIRECT_CATEGORY_NAME=Mac Book Pro M5 Max
DISCORD_ORCHESTRA_CATEGORY_NAME=Agent Orchestra
DISCORD_SETTING_CHANNEL_NAME=setting
DISCORD_LOG_CATEGORY_NAME=Log
DISCORD_LOG_CHANNEL_SUFFIX=-log
DISCORD_RAW_LOG_CHANNEL_SUFFIX=-raw-log
DISCORD_AUTO_CREATE_SESSION_LOGS=true

CLAUDE_ENABLED=true
CODEX_ENABLED=true
GEMINI_ENABLED=true

TASKMESH_DEFAULT_AGENT=claude
TASKMESH_PUBLISH_DELEGATION_EVENTS=true
TASKMESH_STORAGE_DRIVER=sqlite
TASKMESH_DATABASE_PATH=./data/taskmesh.db
TASKMESH_ARTIFACTS_PATH=./artifacts
TASKMESH_SESSION_ROOT=./runtime/sessions
TASKMESH_EXECUTION_MODE=host
TASKMESH_HOST_PROJECT_DIR=/Users/sumin/taskmesh
TASKMESH_DOCKER_BINARY=docker
TASKMESH_SETTINGS_PORT=4319
TASKMESH_SETTINGS_TOKEN_TTL_SECONDS=600
TASKMESH_SETTINGS_ENABLE_TUNNEL=true
TASKMESH_CLOUDFLARED_BINARY=/opt/homebrew/bin/cloudflared
TASKMESH_CLOUDFLARE_TUNNEL_MODE=trycloudflare
TASKMESH_CLOUDFLARE_TUNNEL_TOKEN=
TASKMESH_CLOUDFLARE_TUNNEL_PUBLIC_URL=https://settings.xmincloud.com
TASKMESH_ORCHESTRA_DEFAULT_AGENT=claude

TASKMESH_DOCKER_CLAUDE_IMAGE=taskmesh-claude:latest
TASKMESH_DOCKER_CODEX_IMAGE=taskmesh-codex:latest
TASKMESH_DOCKER_GEMINI_IMAGE=taskmesh-gemini:latest
TASKMESH_DOCKER_CLAUDE_MOUNTS=
TASKMESH_DOCKER_CODEX_MOUNTS=~/.codex:/home/taskmesh/.codex:ro
TASKMESH_DOCKER_GEMINI_MOUNTS=~/.gemini:/home/taskmesh/.gemini:ro
TASKMESH_DOCKER_CLAUDE_ENV=CLAUDE_CODE_OAUTH_TOKEN
TASKMESH_DOCKER_CODEX_ENV=OPENAI_API_KEY
TASKMESH_DOCKER_GEMINI_ENV=GOOGLE_API_KEY

CLAUDE_COMMAND=/Users/sumin/.local/bin/claude
CLAUDE_ARGS=-p,--output-format,text,--add-dir,/Users/sumin/taskmesh,--dangerously-skip-permissions
CODEX_COMMAND=/opt/homebrew/bin/codex
CODEX_ARGS=exec,--skip-git-repo-check,--cd,/Users/sumin/taskmesh,--add-dir,/Users/sumin/taskmesh,--sandbox,danger-full-access,--dangerously-bypass-approvals-and-sandbox,-
GEMINI_COMMAND=/opt/homebrew/bin/gemini
GEMINI_ARGS=
